generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  AUDITOR
  LAB_EXTERNAL
  PHARMACIST
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
}

enum FindingCategory {
  Administrative
  Technical
  Physical
}

enum FindingSeverity {
  Critical
  High
  Medium
  Low
  Informational
}

enum FindingStatus {
  Open
  InProgress
  Remediated
  AcceptedRisk
  Closed
}

enum HipaaControlStatus {
  Implemented
  PartiallyImplemented
  NotImplemented
  NotApplicable
}

enum SafeguardType {
  Administrative
  Technical
  Physical
}

enum IncidentType {
  Breach
  NearMiss
  SecurityEvent
  PolicyViolation
}

enum IncidentStatus {
  Open
  Investigating
  Resolved
  Closed
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique @db.VarChar(255)
  password         String    @db.VarChar(255)
  role             Role      @default(NURSE)
  isActive         Boolean   @default(true) @map("is_active")
  mfaSecret        String?   @map("mfa_secret") @db.VarChar(255)
  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  failedAttempts   Int       @default(0) @map("failed_attempts")
  lockedUntil      DateTime? @map("locked_until")
  lastLogin        DateTime? @map("last_login")
  pwdChangedAt     DateTime  @default(now()) @map("pwd_changed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Historial de contraseñas (últimas 5)
  passwordHistory  PasswordHistory[]

  // Relaciones
  patients         Patient[]
  medicalRecords   MedicalRecord[]
  auditLogs        AuditLog[]
  findings         AuditFinding[]
  hipaaReviews     HipaaControl[]
  incidents        SecurityIncident[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  hash      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_history")
}

model Patient {
  id          Int      @id @default(autoincrement())
  mrn         String   @unique @db.VarChar(50) // Medical Record Number
  nameEnc     String   @map("name_enc") @db.Text // Cifrado AES-256-CBC
  dobEnc      String   @map("dob_enc") @db.Text  // Cifrado
  ssnEnc      String   @map("ssn_enc") @db.Text  // Cifrado
  createdById Int      @map("created_by_id")
  isDeleted   Boolean  @default(false) @map("is_deleted") // Soft delete
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy      User            @relation(fields: [createdById], references: [id])
  medicalRecords MedicalRecord[]

  @@map("patients")
}

model MedicalRecord {
  id           Int      @id @default(autoincrement())
  patientId    Int      @map("patient_id")
  recordType   String   @map("record_type") @db.VarChar(100)
  contentEnc   String   @map("content_enc") @db.Text // Cifrado
  s3ImageKey   String?  @map("s3_image_key") @db.VarChar(500)
  accessedById Int      @map("accessed_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  patient    Patient @relation(fields: [patientId], references: [id])
  accessedBy User    @relation(fields: [accessedById], references: [id])

  @@map("medical_records")
}

model AuditLog {
  id           Int         @id @default(autoincrement())
  userId       Int?        @map("user_id")
  action       AuditAction
  resourceType String      @map("resource_type") @db.VarChar(100)
  resourceId   String?     @map("resource_id") @db.VarChar(100)
  ipAddress    String?     @map("ip_address") @db.VarChar(45)
  userAgent    String?     @map("user_agent") @db.Text
  httpMethod   String      @map("http_method") @db.VarChar(10)
  endpoint     String      @db.VarChar(500)
  statusCode   Int         @map("status_code")
  timestamp    DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
  @@map("audit_logs")
}

model AuditFinding {
  id               Int             @id @default(autoincrement())
  category         FindingCategory
  severity         FindingSeverity
  hipaaControlCode String          @map("hipaa_control_code") @db.VarChar(50)
  description      String          @db.Text
  status           FindingStatus   @default(Open)
  assignedToId     Int?            @map("assigned_to_id")
  dueDate          DateTime?       @map("due_date")
  closedAt         DateTime?       @map("closed_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  assignedTo User? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([category])
  @@map("audit_findings")
}

model HipaaControl {
  id             Int                @id @default(autoincrement())
  safeguardType  SafeguardType      @map("safeguard_type")
  controlCode    String             @unique @map("control_code") @db.VarChar(50)
  description    String             @db.Text
  status         HipaaControlStatus @default(NotImplemented)
  evidenceRef    String?            @map("evidence_ref") @db.Text
  lastReviewedAt DateTime?          @map("last_reviewed_at")
  reviewedById   Int?               @map("reviewed_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  reviewedBy User? @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([safeguardType])
  @@index([status])
  @@map("hipaa_controls")
}

model SecurityIncident {
  id            Int            @id @default(autoincrement())
  type          IncidentType
  description   String         @db.Text
  affectedCount Int            @default(0) @map("affected_count")
  reportedById  Int?           @map("reported_by_id")
  status        IncidentStatus @default(Open)
  resolvedAt    DateTime?      @map("resolved_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  reportedBy User? @relation(fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@map("security_incidents")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
